provider "aws" {
    region = "us-east-1"
    access_key = ""
    secret_key = ""
}
variable "ami_id" {
     default = "ami-0521cb2d60cfbb1a6"
     description = "value"  
}
variable "instance_type" {
    default = "t3.micro"
    description = "ec2 instance type "
}
variable "key_name" {
    default = ""
    description = "ec2-instance key pair "  
}
variable "tags" {

    default = "hammed"
    description = "instance -name"
}
 resource "aws_instance" "pract" {
  ami = var.ami_id
  instance_type = var.instance_type
  key_name = var.key_name
   
   tags = {
      Name = var.tags
   }
 }

